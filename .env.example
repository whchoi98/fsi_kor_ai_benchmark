# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
# Source it before running:  set -a && source .env && set +a && ./run_benchmark.sh

# --- Bedrock auth (choose ONE) ---

# Option A — Bedrock API bearer token (recommended for one-off runs)
AWS_BEARER_TOKEN_BEDROCK=

# Option B — Standard IAM credentials (alternative to bearer token)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Option C — Named profile from ~/.aws/credentials
# AWS_PROFILE=

# --- Region ---
# Default region used when --before-region / --after-region are not passed.
AWS_REGION=ap-northeast-2

# --- Guardrail mode (Stage 1) ---
# Selects which guardrail implementation guardrail_check() dispatches to.
#   sample   — 로컬 패턴 매칭 샘플 (samples/local_guardrail.py).
#              AWS 자원 없이 두-단계 파이프라인 end-to-end 검증용.
#   (empty)  — Amazon Bedrock Guardrails (BEDROCK_GUARDRAIL_ID 사용).
#              ID 미설정 시 no-op pass.
# 실제 FSI 제출 회차에서는 비워두고 BEDROCK_GUARDRAIL_ID 를 설정하세요.
FSI_GUARDRAIL_MODE=

# --- Bedrock Guardrails (used when FSI_GUARDRAIL_MODE is empty) ---
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT
